# Streamlit Cloud secrets template.
# Copy to .streamlit/secrets.toml locally, OR paste the KEY = "value" lines into
# the "Secrets" box at https://share.streamlit.io for your deployed app.
# Streamlit injects these as environment variables at runtime.
#
# NEVER commit .streamlit/secrets.toml — it is gitignored.

# ── Alpaca paper-trading keys (5 accounts) ────────────────────────────────────
ALPACA_DEGEN_KEY      = "PK..."
ALPACA_DEGEN_SECRET   = "..."
ALPACA_SURGE_KEY      = "PK..."
ALPACA_SURGE_SECRET   = "..."
ALPACA_MODERATE_KEY   = "PK..."
ALPACA_MODERATE_SECRET = "..."
ALPACA_SENTINEL_KEY   = "PK..."
ALPACA_SENTINEL_SECRET = "..."
ALPACA_FORTRESS_KEY   = "PK..."
ALPACA_FORTRESS_SECRET = "..."

# ── Planned algos (login 3 / mlc2048@gmail.com) — dashboard shows account,
#    backtester is disabled until the algo's status flips to "ready" ──
ALPACA_REDDIT_PLAY_KEY    = "PK..."
ALPACA_REDDIT_PLAY_SECRET = "..."
ALPACA_ER_PLAY_KEY        = "PK..."
ALPACA_ER_PLAY_SECRET     = "..."
ALPACA_DIVIDEND_PLAY_KEY    = "PK..."
ALPACA_DIVIDEND_PLAY_SECRET = "..."

ALPACA_PAPER_BASE = "https://paper-api.alpaca.markets"
ALPACA_DATA_BASE  = "https://data.alpaca.markets"

# ── Turso (remote SQLite) — required on Streamlit Cloud for persistence ──────
# Create at https://turso.tech — free tier is 9 GB, 500 DBs.
#   turso db create alpaca-backtesting
#   turso db show alpaca-backtesting --url
#   turso db tokens create alpaca-backtesting
TURSO_DATABASE_URL = "libsql://<db>-<org>.turso.io"
TURSO_AUTH_TOKEN   = "..."

# Leave unset locally → falls back to data/backtest.db SQLite file.

# ── Auto-push to production market_pulse ─────────────────────────────────────
# Service-to-service key for POST /api/ingest-pulses on signalpro-pulse.fly.dev.
# Set this so the live engine auto-pushes Go Live Pulses to production.
# INGEST_API_KEY = "..."
