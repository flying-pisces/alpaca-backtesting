# Copy to .env and fill with your Alpaca paper keys.
# Generate keys at: https://app.alpaca.markets/paper/dashboard/overview
# Never commit .env.

# --- Account A: aggressive bucket (Degen / Surge / Moderate) ---
ALPACA_ACCOUNT_A_NAME=aggressive
ALPACA_ACCOUNT_A_ID=PA31GZYCAJRK
ALPACA_ACCOUNT_A_KEY=
ALPACA_ACCOUNT_A_SECRET=

# --- Account B: conservative bucket (Sentinel / Fortress) ---
# Create a second paper account in the Alpaca dashboard, then paste its keys here.
ALPACA_ACCOUNT_B_NAME=conservative
ALPACA_ACCOUNT_B_ID=
ALPACA_ACCOUNT_B_KEY=
ALPACA_ACCOUNT_B_SECRET=

# --- Endpoints (leave as-is for paper) ---
ALPACA_PAPER_BASE=https://paper-api.alpaca.markets
ALPACA_DATA_BASE=https://data.alpaca.markets

# --- Dashboard ---
DASHBOARD_DB_PATH=data/trades.db
