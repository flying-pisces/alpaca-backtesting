# Copy to .env and fill with your Alpaca paper keys.
# Generate keys at https://app.alpaca.markets/paper/dashboard/overview.
# Never commit .env — it is gitignored.
#
# We run one algo per paper account. Alpaca caps paper accounts at ~3
# per login, so these are split across two Alpaca logins:
#
#   Login 1 (primary):    Degen, Surge, Moderate
#   Login 2 (secondary):  Sentinel, Fortress
#
# The dashboard does not care which login an account comes from —
# each account is independently authenticated with its own key/secret.

# --- Degen (login 1) ---
ALPACA_DEGEN_KEY=
ALPACA_DEGEN_SECRET=

# --- Surge (login 1) ---
ALPACA_SURGE_KEY=
ALPACA_SURGE_SECRET=

# --- Moderate (login 1) ---
ALPACA_MODERATE_KEY=
ALPACA_MODERATE_SECRET=

# --- Sentinel (login 2) ---
ALPACA_SENTINEL_KEY=
ALPACA_SENTINEL_SECRET=

# --- Fortress (login 2) ---
ALPACA_FORTRESS_KEY=
ALPACA_FORTRESS_SECRET=

# ── Planned algos (login 3) — scaffolded, no strategy selector yet ──────────
# Adding keys here lets the dashboard show the account live; running the
# backtester is blocked until status flips to "ready" in config/algos.yaml.

# --- Reddit Play (login 3) — PLANNED ---
ALPACA_REDDIT_PLAY_KEY=
ALPACA_REDDIT_PLAY_SECRET=

# --- ER Play (login 3) — PLANNED ---
ALPACA_ER_PLAY_KEY=
ALPACA_ER_PLAY_SECRET=

# --- Dividend Play (login 3) — PLANNED ---
ALPACA_DIVIDEND_PLAY_KEY=
ALPACA_DIVIDEND_PLAY_SECRET=

# --- Endpoints (leave as-is for paper) ---
ALPACA_PAPER_BASE=https://paper-api.alpaca.markets
ALPACA_DATA_BASE=https://data.alpaca.markets

# --- Dashboard storage ---
DASHBOARD_DB_PATH=data/backtest.db

# --- Auto-push live pulses to market_pulse (optional) ---
# When set, the live engine automatically pushes new go_live pulses to
# market_pulse's SQLite DB after every cycle. Leave blank to skip.
# Only works when the path is accessible (e.g. local dev, shared volume).
# On Streamlit Cloud this is typically unset; use the CLI cron instead.
# AUTO_PUSH_SQLITE_PATH=~/projects/market_pulse/pulses.db

# --- Auto-push via HTTP to production market_pulse (preferred) ---
# Service-to-service key that matches INGEST_API_KEY on signalpro-pulse.fly.dev.
# When set, the live engine POSTs batches to /api/ingest-pulses after each cycle
# — no SQLite lock contention. Falls back to SQLite path above if this is unset.
# INGEST_API_KEY=
